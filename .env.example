# =============================================================================
# Configuration des outils de sécurité
# =============================================================================
# Copiez ce fichier en .env et remplissez les valeurs
# Usage: cp .env.example .env

# -----------------------------------------------------------------------------
# Snyk - Analyse des dépendances
# -----------------------------------------------------------------------------
# Obtenez un token gratuit sur https://snyk.io/
# Le token est optionnel, mais recommandé pour une meilleure analyse
SNYK_TOKEN=

# -----------------------------------------------------------------------------
# OWASP Dependency Check - OSS Index (Sonatype)
# -----------------------------------------------------------------------------
# Créez un compte gratuit sur https://ossindex.sonatype.org/user/register
# Puis générez un token sur https://ossindex.sonatype.org/user/settings
OSS_INDEX_USERNAME=
OSS_INDEX_API_KEY=

# -----------------------------------------------------------------------------
# OWASP Dependency Check - NVD API Key
# -----------------------------------------------------------------------------
# Obtenez une clé API gratuite sur https://nvd.nist.gov/developers/request-an-api-key
# La clé API accélère considérablement les mises à jour de la base de vulnérabilités
# Sans clé API, les scans peuvent prendre plusieurs minutes au lieu de quelques secondes
NVD_API_KEY=

# -----------------------------------------------------------------------------
# DefectDojo - Agrégateur de rapports (optionnel)
# -----------------------------------------------------------------------------
# Clé secrète pour DefectDojo (générez une clé aléatoire forte)
# Exemple: openssl rand -base64 32
DD_SECRET_KEY=change-me-in-production

# -----------------------------------------------------------------------------
# Configuration des scans
# -----------------------------------------------------------------------------
# Répertoire du projet à scanner (relatif au dossier de sécurité)
# Exemples: ./elearning, ./mon-projet, ./app
PROJECT_DIR=nomprojet
# chemin vers le dockerfile du projet, depuis la racine du projet
DOCKERFILE=chemin/vers/dockerfile

# URL de base pour les scans DAST
# Exemples: https://dev.example.com, https://staging.myapp.fr
TARGET_URL=https://dev.cebios-lms.fr

# Image Docker à scanner
# Exemples: myregistry.com/app:latest, nginx:latest
DOCKER_IMAGE=cebios-lms:latest

# -----------------------------------------------------------------------------
# Notifications (optionnel)
# -----------------------------------------------------------------------------
# Webhook Slack pour notifications
SLACK_WEBHOOK_URL=

# Email pour notifications
NOTIFICATION_EMAIL=
