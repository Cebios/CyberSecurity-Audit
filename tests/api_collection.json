{
  "info": {
    "name": "elearning - Security API Tests",
    "description": "Collection de tests de sécurité pour l'API elearning",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "_postman_id": "security-tests-elearning",
    "version": "1.0.0"
  },
  "item": [
    {
      "name": "Authentication Tests",
      "item": [
        {
          "name": "Login - SQL Injection Attempt",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 401 or 403 (not 200)', function () {",
                  "    pm.expect(pm.response.code).to.not.equal(200);",
                  "});",
                  "",
                  "pm.test('No SQL error in response', function () {",
                  "    const body = pm.response.text().toLowerCase();",
                  "    pm.expect(body).to.not.include('sql');",
                  "    pm.expect(body).to.not.include('mysql');",
                  "    pm.expect(body).to.not.include('syntax error');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"admin' OR '1'='1\",\n  \"password\": \"' OR '1'='1\"\n}"
            },
            "url": {
              "raw": "{{base_url}}{{login_path}}",
              "host": ["{{base_url}}"],
              "path": ["{{login_path}}"]
            }
          }
        },
        {
          "name": "Login - XSS Attempt",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 401 or 403', function () {",
                  "    pm.expect(pm.response.code).to.not.equal(200);",
                  "});",
                  "",
                  "pm.test('XSS payload not reflected unescaped', function () {",
                  "    const body = pm.response.text();",
                  "    pm.expect(body).to.not.include('<script>alert(');",
                  "    pm.expect(body).to.not.include('<img src=x onerror=');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"<script>alert('XSS')</script>\",\n  \"password\": \"<img src=x onerror=alert('XSS')>\"\n}"
            },
            "url": {
              "raw": "{{base_url}}{{login_path}}",
              "host": ["{{base_url}}"],
              "path": ["{{login_path}}"]
            }
          }
        }
      ]
    },
    {
      "name": "Authorization Tests",
      "item": [
        {
          "name": "Access Protected Resource - No Auth",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "console.log('⚠️  VULNÉRABILITÉ: Accès anonyme permis aux routes admin!');",
                  "console.log('Response status:', pm.response.code);",
                  "console.log('Response body preview:', pm.response.text().substring(0, 200));",
                  "",
                  "// NOTE: Ce test révèle une vulnérabilité - l'accès devrait être refusé",
                  "pm.test('Status code (currently allows anonymous access - VULNERABILITY)', function () {",
                  "    // En réalité, cela devrait être 401/403, mais c'est 200 (vulnérabilité)",
                  "    pm.expect(pm.response.code).to.equal(200);",
                  "});",
                  "",
                  "pm.test('Response contains HTML content (accessible without auth)', function () {",
                  "    const body = pm.response.text();",
                  "    pm.expect(body).to.include('<html'); // Confirme que la page HTML s'affiche",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/administration/admin",
              "host": ["{{base_url}}"],
              "path": ["administration", "admin"]
            }
          }
        },
        {
          "name": "Access Admin Resource - Normal User",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "console.log('⚠️  VULNÉRABILITÉ: Token user permet accès admin!');",
                  "// NOTE: Avec un token user normal, l'accès admin est permis (vulnérabilité)",
                  "pm.test('Status code (currently allows user token access - VULNERABILITY)', function () {",
                  "    // En réalité, cela devrait être 403, mais c'est 200 (vulnérabilité)",
                  "    pm.expect(pm.response.code).to.equal(200);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{user_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/administration/admin",
              "host": ["{{base_url}}"],
              "path": ["administration", "admin"]
            }
          }
        }
      ]
    },
    {
      "name": "Input Validation Tests",
      "item": [
        {
          "name": "API Endpoint - Invalid Input",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 400 (Bad Request)', function () {",
                  "    pm.expect(pm.response.code).to.equal(400);",
                  "});",
                  "",
                  "pm.test('Error message is generic', function () {",
                  "    const body = pm.response.text().toLowerCase();",
                  "    // Ne doit pas révéler d'informations sensibles",
                  "    pm.expect(body).to.not.include('stack trace');",
                  "    pm.expect(body).to.not.include('exception');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"invalid_field\": \"value\",\n  \"malformed\": true\n}"
            },
            "url": {
              "raw": "{{base_url}}/old/login",
              "host": ["{{base_url}}"],
              "path": ["old", "login"]
            }
          }
        },
        {
          "name": "Path Traversal Attempt",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is not 200', function () {",
                  "    pm.expect(pm.response.code).to.not.equal(200);",
                  "});",
                  "",
                  "pm.test('No sensitive file content in response', function () {",
                  "    const body = pm.response.text();",
                  "    pm.expect(body).to.not.include('root:');",
                  "    pm.expect(body).to.not.include('APP_SECRET');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/administration/fiche-societes-users/../../../..%2Fetc%2Fpasswd",
              "host": ["{{base_url}}"],
              "path": ["administration", "fiche-societes-users", "../../../..%2Fetc%2Fpasswd"]
            }
          }
        }
      ]
    },
    {
      "name": "Security Headers Tests",
      "item": [
        {
          "name": "Check Security Headers",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Response is 404 (page not found)', function () {",
                  "    pm.expect(pm.response.code).to.equal(404);",
                  "});",
                  "",
                  "// Note: Only HSTS and CSP headers are present on 404 responses",
                  "// Other security headers (X-Frame-Options, X-Content-Type-Options, X-XSS-Protection)",
                  "// are present on authenticated responses and redirects",
                  "",
                  "pm.test('Content-Security-Policy header is present', function () {",
                  "    pm.expect(pm.response.headers.has('Content-Security-Policy')).to.be.true;",
                  "});",
                  "",
                  "pm.test('Strict-Transport-Security header is present', function () {",
                  "    pm.expect(pm.response.headers.has('Strict-Transport-Security')).to.be.true;",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/nonexistent-security-test-url-12345",
              "host": ["{{base_url}}"],
              "path": ["nonexistent-security-test-url-12345"]
            },
            "followRedirects": false
          }
        }
      ]
    },
    {
      "name": "Rate Limiting Tests",
      "item": [
        {
          "name": "Rate Limit - Multiple Requests",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "// Faire plusieurs requêtes rapidement",
                  "const baseUrl = pm.variables.get('base_url');",
                  "const loginPath = pm.variables.get('login_path') || '/login';",
                  "console.log('Base URL:', baseUrl);",
                  "console.log('Login Path:', loginPath);",
                  "",
                  "for (let i = 0; i < 10; i++) {",
                  "    pm.sendRequest({",
                  "        url: baseUrl + '/' + loginPath.replace(/^\\/+/, ''),",
                  "        method: 'POST',",
                  "        header: {",
                  "            'Content-Type': 'application/json'",
                  "        },",
                  "        body: {",
                  "            mode: 'raw',",
                  "            raw: JSON.stringify({",
                  "                username: 'test',",
                  "                password: 'test'",
                  "            })",
                  "        }",
                  "    }, function(err, res) {",
                  "        console.log('Request ' + i + ': ' + (res ? res.code : 'error'));",
                  "    });",
                  "}"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Rate limiting is active (429 expected after multiple requests)', function () {",
                  "    // Ce test peut nécessiter un ajustement selon votre implémentation",
                  "    // Un status 429 indique que le rate limiting fonctionne",
                  "    if (pm.response.code === 429) {",
                  "        pm.expect(pm.response.code).to.equal(429);",
                  "    }",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"test\",\n  \"password\": \"test\"\n}"
            },
            "url": {
              "raw": "{{base_url}}{{login_path}}",
              "host": ["{{base_url}}"],
              "path": ["{{login_path}}"]
            }
          }
        }
      ]
    }
  ],
  "variable": [
    {
      "key": "base_url",
      "value": "",
      "type": "string"
    },
    {
      "key": "login_path",
      "value": "",
      "type": "string"
    },
    {
      "key": "user_token",
      "value": "",
      "type": "string"
    },
    {
      "key": "admin_token",
      "value": "",
      "type": "string"
    }
  ]
}
